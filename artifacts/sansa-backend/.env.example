# --- Production (MilesWeb / live) — replace every placeholder before go-live ---
# Generate SESSION_SECRET:  openssl rand -base64 48
# Never commit a real .env file; set variables in cPanel "Node.js" → Environment Variables.

NODE_ENV=production
PORT=8080
APP_BASE_URL=https://sansaai.in
CORS_ORIGINS=https://sansaai.in,https://www.sansaai.in,https://api.sansaai.in

ADMIN_USERNAME=admin@sansai.in
# Do not use Admin@123 in production — pick a long random password.
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
# Must be >= 32 random characters, not a dictionary word or "change-this-...".
SESSION_SECRET=REPLACE_WITH_OPENSSL_RAND_BASE64_48

# Optional. Leave empty to use cPanel-safe JSON files in data/.
DATABASE_URL=
USE_OPENAI=false
FREE_WEB_SEARCH=true
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_TEXT_MODEL=gpt-4o-mini
VECTORENGINE_API_KEY=
VECTOR_ENGINE_API_KEY=
VECTORENGINE_API_URL=https://api.vectorengine.ai
REPLICATE_API_TOKEN=
REPLICATE_VIDEO_MODEL=
REPLICATE_SOUND_MODEL=
REPLICATE_MUSIC_MODEL=
GOOGLE_AI_API_KEY=

SANSA_UPI_ID=yourname@upi
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_CALLBACK_URL=https://sansaai.in/app

PYTHON_BIN=python3
MAX_UPLOAD_MB=25
